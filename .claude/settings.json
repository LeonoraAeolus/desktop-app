{
  "permissions": {
    "allow": [
      "Read",
      "Edit", 
      "MultiEdit",
      "Write",
      "Glob",
      "Grep",
      "LS",
      "Task",
      "WebFetch",
      "WebSearch",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd:*)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(docker:*)",
      "Bash(python:*)",
      "Bash(node:*)",
      "Bash(pip:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write(*.js)|Write(*.ts)|Write(*.jsx)|Write(*.tsx)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format-code.sh $file",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write(package.json)",
        "hooks": [
          {
            "type": "command", 
            "command": ".claude/hooks/check-deps.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Write(src/**/*.test.*)|Write(tests/**/*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-tests.sh $file",
            "timeout": 120
          }
        ]
      }
    ],
    
    "PreToolUse": [
      {
        "matcher": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/git-workflow.sh protect-main",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-check.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Bash(git push *)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/git-workflow.sh suggest-pr",
            "timeout": 10
          }
        ]
      }
    ],

    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-cleanup.sh",
            "timeout": 30
          }
        ]
      }
    ],

    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-session.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },

  "environment": {
    "NODE_ENV": "development",
    "FORCE_COLOR": "1"
  }

}

