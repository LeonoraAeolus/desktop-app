{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(source:*)",
      "Bash(find:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(tree:*)",
      "Bash(ruff:*)",
      "Bash(touch:*)",
      "Bash(cat:*)",
      "Bash(ruff check:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(python -m pytest:*)",
      "Bash(python3 -m pytest:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:github.com)"
    ],
    "deny": []
  }
}

{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-code-change.sh"
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command", 
            "command": "echo '⚡ Running bash command...' && echo 'Command: $CLAUDE_TOOL_ARGS' >> .claude/bash-history.log"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-code-change.sh"
          }
        ]
      },
      {
        "matcher": "^(Bash.*build|Bash.*cargo tauri build)$",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-build.sh"
          }
        ]
      },
      {
        "matcher": "^(Bash.*test|Bash.*npm test|Bash.*cargo test)$",
        "hooks": [
          {
            "type": "command", 
            "command": "echo '🧪 Tests completed - generating report...' && echo 'Test run: $(date)' >> .claude/test-history.log"
          }
        ]
      }
    ],
    "UserSubmitPrompt": [
      {
        "matcher": ".*commit.*|.*push.*|.*merge.*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/git-operation.sh"
          }
        ]
      },
      {
        "matcher": ".*build.*|.*deploy.*|.*release.*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-build.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "project_context": {
    "name": "CreativeKit Desktop",
    "type": "tauri-app",
    "languages": ["typescript", "rust", "python"],
    "frameworks": ["react", "tauri", "fastapi"],
    "commands": {
      "dev": "cargo tauri dev",
      "build": "cargo tauri build", 
      "test": "npm test && cd src-tauri && cargo test",
      "lint": "npm run lint && cd src-tauri && cargo clippy",
      "format": "npm run format && cd src-tauri && cargo fmt"
    }
  },
  "validation_rules": {
    "max_file_size": "500_lines",
    "required_tests": true,
    "code_review": true,
    "security_check": true
  }
}